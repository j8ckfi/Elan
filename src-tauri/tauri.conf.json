{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elan",
  "version": "0.1.0",
  "identifier": "app.elan.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:host && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Elan",
        "width": 1040,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/elan-host"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1NEVGRkZEMDYxRTZDOQpSV1RKNW1IUS8rOVVCTWhBRTRWWU5DQ2xKZHd5UGtrRUsvS0k2MnlVR2tVUXVzWkQ4a0xuOEx0aQo=",
      "endpoints": [
        "https://github.com/j8ckfi/Elan/releases/latest/download/latest.json"
      ]
    }
  }
}